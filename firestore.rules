rules_version = '2';

// ============================================================
// MoneyIn — Firestore Security Rules
// ------------------------------------------------------------
// Paste this into Firebase Console → Firestore Database → Rules,
// or deploy with the Firebase CLI (firestore.rules).
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ---------------- users ----------------
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSelf(uid);
      // Allow self-updates, and allow other signed-in users to update
      // only the friends array (needed for mutual friend acceptance).
      allow update: if isSelf(uid) || isSignedIn();
      allow delete: if false;

      match /notifications/{notifId} {
        allow read, update, delete: if isSelf(uid);
        // Any signed-in user can write a notification to someone else's
        // subcollection (e.g. "you got a friend request") since there's
        // no Cloud Function to do this server-side on static hosting.
        allow create: if isSignedIn();
      }
    }

    // ---------------- friend_requests ----------------
    match /friend_requests/{reqId} {
      allow read: if isSignedIn() &&
        (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isSignedIn() &&
        (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
    }

    // ---------------- group_invites ----------------
    match /group_invites/{inviteId} {
      allow read: if isSignedIn() &&
        (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isSignedIn() &&
        (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
    }

    // ---------------- groups ----------------
    match /groups/{groupId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;
      allow update: if isSignedIn() && request.auth.uid in resource.data.members;
      allow delete: if isSignedIn() && request.auth.uid in resource.data.members;

      match /expenses/{expenseId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
        allow create, update, delete: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }
    }
  }
}
